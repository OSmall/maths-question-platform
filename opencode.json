{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["bunx", "--bun", "shadcn", "mcp"],
      "enabled": true
    },
    "dbhub": {
      "type": "local",
      "command": ["dbhub", "--transport", "stdio", "--dsn", "{{connection string}}"],
      "enabled": false
    }
  }
}
