{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["bunx", "--bun", "shadcn", "mcp"],
      "enabled": true
    },
    "dbhub": {
      "type": "local",
      "command": ["dbhub"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["playwright-mcp", "--browser", "chromium", "--viewport-size", "1440x900"],
      "enabled": true
    }
  }
}
