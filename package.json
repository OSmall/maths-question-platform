{
  "name": "maths-question-platform",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation bun --bun next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation bun --bun next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && bun run --bun build && bun run --bun start",
    "typecheck": "bun --bun tsc --noEmit",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "smoke:payload": "cross-env NODE_OPTIONS=--no-deprecation bun --bun scripts/payload-smoke.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation bun --bun next start",
    "test": "bun run test:unit && bun run test:int && bun run test:e2e",
    "test:unit": "cross-env APP_ENV=test bun test tests/unit",
    "test:int": "cross-env APP_ENV=integration-test bun test --preload tests/int/setup-int-test.ts tests/int",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" bunx playwright test --config=playwright.config.ts",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "ci:build": "payload migrate && bun run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.5",
    "@payloadcms/db-vercel-postgres": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-vercel-blob": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@t3-oss/env-core": "^0.13.11",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/postcss": "^4.1.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "eslint-plugin-neverthrow": "^1.1.4",
    "graphql": "^16.12.0",
    "hugeicons-react": "^0.3.0",
    "lucide-react": "^0.562.0",
    "neverthrow": "^8.2.0",
    "next": "16.2.6",
    "next-safe-action": "^8.1.8",
    "next-themes": "^0.4.6",
    "payload": "3.84.1",
    "postcss": "^8.5.6",
    "react": "~19.2.1",
    "react-dom": "~19.2.1",
    "remeda": "^2.33.6",
    "sharp": "0.34.2",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.5",
    "@electric-sql/pglite-socket": "^0.1.5",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "16.3.0",
    "@types/bun": "latest",
    "@types/node": "^22.19.1",
    "@types/react": "~19.1.8",
    "@types/react-dom": "~19.1.6",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.6",
    "jiti": "^2.7.0",
    "playwright": "1.58.2",
    "playwright-core": "1.58.2",
    "prettier": "^3.7.3",
    "shadcn": "^4.0.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=20.9.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@latest"
}
